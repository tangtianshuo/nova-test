# AaaS 执行引擎环境配置
# 严格遵循 docs/design/02_概要设计文档_v1.0.md

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_KEY=queue:agent_tasks
REDIS_STREAM_PREFIX=pubsub:agent_stream:

# 数据库配置
DATABASE_URL=postgresql://postgres:Qq1034524076@localhost:5432/nova_test?schema=public

# Fara-7B 视觉模型 RPC 配置
FARA_API_URL=http://localhost:8001/v1/chat/completions
FARA_API_KEY=sk-dev-key
VISION_MODEL_NAME=fara-7b-vision

# S3/MinIO 配置
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=nova-test
S3_REGION=us-east-1

# 执行引擎配置
MAX_STEPS=10
HIL_CONFIDENCE_THRESHOLD=0.7
BROWSER_HEADLESS=true
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720

# API 配置
API_HOST=0.0.0.0
API_PORT=8002
LOG_LEVEL=INFO
